# Environment Variables Configuration
# Copy this file to .env and fill in your actual values

# PostgreSQL Database Connection 
# For local Docker use: postgresql://postgres:password@localhost:5432/postgres
# For Supabase use the connection pooling URL provided in their dashboard
DATABASE_URL=postgresql://user:password@host:port/your_db_name

# Admin Dashboard Password (Change this!)
ADMIN_PASSWORD=admin123

# Server Port (Optional - Render sets this automatically)
# PORT=3000
